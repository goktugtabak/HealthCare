# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://healthai_user:healthai_password@localhost:5434/healthai_db"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP). Leave SMTP_USER blank to skip outbound email; backend logs a warn.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@healthai.app
EMAIL_FROM_NAME=HEALTH AI

# CORS
FRONTEND_URL=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Admin
ADMIN_EMAIL=admin@healthai.edu.tr

# Auth-specific rate limit (NFR-07: 10 fail / 15 min / IP)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Inactivity / pending-deletion sweep
INACTIVITY_TIMEOUT_MS=1800000
DELETION_TTL_MS=259200000

# Optional dev bypass for /requireVerified middleware
ALLOW_UNVERIFIED=false
