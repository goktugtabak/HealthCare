# Top-level docker-compose env. Copy to .env and edit. The compose
# file references these via `${NAME:-default}` and `${NAME:?}`.

# REQUIRED: 32+ character random string. Generate with:
#   openssl rand -hex 48
# Backend hard-fails on boot in production if missing or weak.
JWT_SECRET=

# Public hostname for Caddy. Leave as `localhost` for local TLS via
# Caddy's internal CA (browser self-signed warning). Set to a real
# domain to auto-issue Let's Encrypt certs.
DOMAIN=localhost
ACME_EMAIL=admin@healthai.local

# CORS / origin whitelist for backend
FRONTEND_URL=https://localhost,http://localhost:8080

# Frontend build args
VITE_API_URL=/api
VITE_APP_NAME=HEALTH AI
VITE_USE_MOCK_DATA=false

# SMTP (leave blank to skip outbound email; backend logs a warn)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@healthai.app

# 72h deletion grace period in milliseconds (NFR-10).
# Set to 60000 (1 min) for quick demo/testing.
DELETION_TTL_MS=259200000

# Set to true ONLY in dev to bypass requireVerified middleware
ALLOW_UNVERIFIED=false
