VITE_API_URL=http://localhost:5001/api
VITE_APP_NAME=HEALTH AI

# Real-mode is now the default. Set to true to demo offline against the
# bundled mock data (useful for unit tests and disconnected presentations).
VITE_USE_MOCK_DATA=false

# Polling cadence (real-mode only). Override in production for higher cadence
# server load. Default 5s notifications / 10s meetings.
VITE_POLL_NOTIFICATIONS_MS=5000
VITE_POLL_MEETINGS_MS=10000
